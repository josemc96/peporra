@baseUrl = http://127.0.0.1:4000
@email = test@peporra.com
@password = password123

### Health check
GET {{baseUrl}}/health

### Registro
# @name register
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}",
  "alias": "TestUser"
}

### Login
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### Mi perfil (usa el accessToken de la respuesta de login/register de arriba)
GET {{baseUrl}}/api/auth/me
Authorization: Bearer {{login.response.body.accessToken}}

### Refrescar access token
POST {{baseUrl}}/api/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{login.response.body.refreshToken}}"
}

### Logout (invalida los refresh tokens emitidos)
POST {{baseUrl}}/api/auth/logout
Authorization: Bearer {{login.response.body.accessToken}}

### Crear peña (usa el accessToken del login de arriba)
# @name createGroup
POST {{baseUrl}}/api/groups
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "name": "Peña de prueba",
  "season": "2026-2027"
}

### Unirse a una peña por inviteCode
POST {{baseUrl}}/api/groups/join
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "inviteCode": "{{createGroup.response.body.group.inviteCode}}"
}

### Mis peñas
GET {{baseUrl}}/api/groups
Authorization: Bearer {{login.response.body.accessToken}}

### Detalle de una peña
GET {{baseUrl}}/api/groups/{{createGroup.response.body.group._id}}
Authorization: Bearer {{login.response.body.accessToken}}

### Forzar sincronización de partidos de La Liga (requiere role admin)
POST {{baseUrl}}/api/admin/sync-matches
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "season": "2026-2027"
}

### Ver los partidos sincronizados (todos los de la temporada actual)
GET {{baseUrl}}/api/matches
Authorization: Bearer {{login.response.body.accessToken}}

### Ver los partidos de una jornada concreta
GET {{baseUrl}}/api/matches?matchday=1
Authorization: Bearer {{login.response.body.accessToken}}

### Crear/actualizar mi predicción de un partido (sustituye matchId por un _id real de /api/matches)
PUT {{baseUrl}}/api/predictions
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "matchId": "6a4ba5563bf5892d31bcb735",
  "predictedHome": 2,
  "predictedAway": 1
}

### Mis predicciones (filtro opcional por jornada/temporada)
GET {{baseUrl}}/api/predictions?matchday=1&season=2026-2027
Authorization: Bearer {{login.response.body.accessToken}}

### Mi predicción para un partido concreto
GET {{baseUrl}}/api/predictions/6a4ba5563bf5892d31bcb735
Authorization: Bearer {{login.response.body.accessToken}}

### Crear/actualizar mi predicción de clasificación (fase 'ida' o 'vuelta')
PUT {{baseUrl}}/api/standings-predictions
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "season": "2026-2027",
  "phase": "ida",
  "predictedTable": [
    { "position": 1, "team": "Real Madrid CF" },
    { "position": 2, "team": "FC Barcelona" }
  ]
}

### Mis predicciones de clasificación
GET {{baseUrl}}/api/standings-predictions?season=2026-2027
Authorization: Bearer {{login.response.body.accessToken}}

### Mi predicción de clasificación de una fase concreta
GET {{baseUrl}}/api/standings-predictions/2026-2027/ida
Authorization: Bearer {{login.response.body.accessToken}}

### Crear/actualizar mi predicción de Pichichi o Zamora
PUT {{baseUrl}}/api/award-predictions
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "season": "2026-2027",
  "award": "pichichi",
  "predictedPlayer": "Kylian Mbappé"
}

### Mis predicciones de premios
GET {{baseUrl}}/api/award-predictions?season=2026-2027
Authorization: Bearer {{login.response.body.accessToken}}

### Mi predicción de un premio concreto
GET {{baseUrl}}/api/award-predictions/2026-2027/pichichi
Authorization: Bearer {{login.response.body.accessToken}}

### Forzar sincronización de goleadores (requiere role admin)
POST {{baseUrl}}/api/admin/sync-scorers
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "season": "2026-2027"
}

### Ver clasificación de goleadores (útil mientras decides tu predicción de Pichichi)
GET {{baseUrl}}/api/scorers?season=2026-2027
Authorization: Bearer {{login.response.body.accessToken}}

### Crear partido manual de Copa del Rey/Supercopa (requiere role admin, isKnockout se pone a true solo)
# @name createCupMatch
POST {{baseUrl}}/api/matches
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "season": "2026-2027",
  "competition": "copa_del_rey",
  "homeTeam": "Real Madrid CF",
  "awayTeam": "FC Barcelona",
  "startTime": "2027-04-25T20:00:00.000Z"
}

### Introducir el resultado final (90') de ese partido (requiere role admin)
PUT {{baseUrl}}/api/matches/{{createCupMatch.response.body.match._id}}/result
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "homeScore": 1,
  "awayScore": 1
}

### Introducir quién se clasifica (solo si acabó empatado a los 90', requiere role admin)
PUT {{baseUrl}}/api/matches/{{createCupMatch.response.body.match._id}}/qualifier
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "qualifier": "home"
}

### Crear/actualizar mi predicción de "quién se clasifica" (usa el _id del partido creado arriba)
PUT {{baseUrl}}/api/qualifier-predictions
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "matchId": "{{createCupMatch.response.body.match._id}}",
  "predictedQualifier": "home"
}

### Mis predicciones de "quién se clasifica"
GET {{baseUrl}}/api/qualifier-predictions
Authorization: Bearer {{login.response.body.accessToken}}

### Mi predicción de "quién se clasifica" para un partido concreto
GET {{baseUrl}}/api/qualifier-predictions/{{createCupMatch.response.body.match._id}}
Authorization: Bearer {{login.response.body.accessToken}}

### Ver la configuración de reglas de mi peña (cualquier miembro; usa el _id de createGroup)
GET {{baseUrl}}/api/groups/{{createGroup.response.body.group._id}}/rule-settings?season=2026-2027
Authorization: Bearer {{login.response.body.accessToken}}

### Activar una regla y ajustar sus puntos, + activar Copa del Rey (solo el admin de la peña)
PUT {{baseUrl}}/api/groups/{{createGroup.response.body.group._id}}/rule-settings
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "season": "2026-2027",
  "rules": [
    { "key": "exact_score", "points": 3, "active": true },
    { "key": "correct_sign", "points": 1, "active": true }
  ],
  "enabledCompetitions": ["copa_del_rey"]
}

### Crear un multiplicador x2 para toda la jornada 1 de mi peña (solo el admin de la peña)
# @name createMultiplier
POST {{baseUrl}}/api/groups/{{createGroup.response.body.group._id}}/multipliers
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "season": "2026-2027",
  "scope": "matchday",
  "matchday": 1,
  "multiplier": 2
}

### Ver los multiplicadores de mi peña
GET {{baseUrl}}/api/groups/{{createGroup.response.body.group._id}}/multipliers?season=2026-2027
Authorization: Bearer {{login.response.body.accessToken}}

### Borrar un multiplicador (solo el admin de la peña)
DELETE {{baseUrl}}/api/groups/{{createGroup.response.body.group._id}}/multipliers/{{createMultiplier.response.body.multiplier._id}}
Authorization: Bearer {{login.response.body.accessToken}}

### Introducir el resultado real de Pichichi/Zamora (requiere role admin GLOBAL, no el de la peña)
PUT {{baseUrl}}/api/admin/award-results
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "season": "2026-2027",
  "award": "pichichi",
  "realPlayer": "Kylian Mbappé"
}

### Ver los resultados reales de premios ya introducidos
GET {{baseUrl}}/api/award-results?season=2026-2027
Authorization: Bearer {{login.response.body.accessToken}}

### Forzar el cálculo de puntos (requiere role admin GLOBAL) — puntúa lo que esté pendiente
POST {{baseUrl}}/api/admin/calculate-scores
Content-Type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
  "season": "2026-2027"
}

### Ver el ranking de mi peña (cualquier miembro; usa el _id de createGroup)
GET {{baseUrl}}/api/groups/{{createGroup.response.body.group._id}}/ranking?season=2026-2027
Authorization: Bearer {{login.response.body.accessToken}}
